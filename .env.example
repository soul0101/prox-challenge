# If you're logged in via the `claude` CLI (Claude Pro/Team subscription),
# you don't need to set anything here — the Claude Agent SDK inherits that auth.
#
# Otherwise, provide an Anthropic API key:
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the runtime model. Accepts sonnet | opus | haiku | full-id.
# CLAUDE_MODEL=sonnet

# Optional: override the ingest-time vision model.
# INGEST_MODEL=sonnet

# Optional: parallelism for the ingest vision pass.
# INGEST_CONCURRENCY=4
